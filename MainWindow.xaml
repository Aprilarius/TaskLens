<Window x:Class="TaskLens.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskLens"
        Icon="Assets/TaskLens.ico"
        Width="1280"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#EEF3FB">
  <Window.Resources>
    <Style x:Key="NavButton"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#C8D4EF" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="14,11" />
      <Setter Property="Margin" Value="7,2" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style x:Key="QuietButton"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#E8EEFA" />
      <Setter Property="Foreground" Value="#28436B" />
    </Style>
    <Style x:Key="DangerButton"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#FFF0F1" />
      <Setter Property="Foreground" Value="#B4232D" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="236" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#111B36">
      <Grid Margin="12">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Margin="12,18,12,24">
          <TextBlock Text="◉  TaskLens"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="White" />
          <TextBlock x:Name="TaglineText"
                     Margin="29,5,0,0"
                     Foreground="#91A3CC"
                     FontSize="11" />
        </StackPanel>
        <StackPanel x:Name="NavPanel" Grid.Row="1" />
        <Border Grid.Row="2"
                Margin="5,8"
                Padding="12"
                Background="#1B294B"
                CornerRadius="12">
          <StackPanel>
            <TextBlock x:Name="OfflineLabel"
                       Text="●  OFFLINE"
                       Foreground="#6FE3B1"
                       FontWeight="SemiBold"
                       FontSize="11" />
            <TextBlock x:Name="SidePrivacy"
                       Margin="0,7,0,0"
                       Foreground="#AEBBDA"
                       FontSize="11" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Border x:Name="PrivacyBar" Background="#DCEBFF" Padding="18,11">
        <DockPanel>
          <TextBlock Text="◈"
                     Margin="0,0,10,0"
                     FontSize="18"
                     Foreground="#2764E7" />
          <TextBlock x:Name="PrivacyText"
                     VerticalAlignment="Center"
                     Foreground="#24446F" />
          <Button x:Name="RefreshButton"
                  DockPanel.Dock="Right"
                  Margin="12,0,0,0"
                  Padding="13,6"
                  HorizontalAlignment="Right"
                  Click="Refresh_Click" />
        </DockPanel>
      </Border>

      <Grid Grid.Row="1">
        <ScrollViewer x:Name="PageScroll"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <ContentControl x:Name="PageHost" Margin="26,24,26,28" />
        </ScrollViewer>
        <Grid x:Name="BusyLayer"
              Background="#55FFFFFF"
              Visibility="Collapsed">
          <Border Padding="30"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="White"
                  CornerRadius="16">
            <StackPanel>
              <ProgressBar Width="220" Height="5" IsIndeterminate="True" />
              <TextBlock x:Name="BusyText"
                         Margin="0,16,0,0"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>

      <Border x:Name="FooterBar"
              Grid.Row="2"
              Padding="18,8"
              Background="#F9FBFF"
              BorderBrush="#DDE4EF"
              BorderThickness="0,1,0,0">
        <DockPanel>
          <TextBlock x:Name="StatusText" Foreground="#64728C" />
          <TextBlock x:Name="VersionText"
                     DockPanel.Dock="Right"
                     Foreground="#8B96AA" />
        </DockPanel>
      </Border>
    </Grid>

    <Grid x:Name="Onboarding"
          Grid.ColumnSpan="2"
          Background="#EAF1FB"
          Visibility="Collapsed">
      <Border Width="760"
              MaxHeight="620"
              Padding="58"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="White"
              CornerRadius="28">
        <Border.Effect>
          <DropShadowEffect Color="#476083"
                            BlurRadius="34"
                            ShadowDepth="10"
                            Opacity="0.22" />
        </Border.Effect>
        <StackPanel>
          <Border Width="70"
                  Height="70"
                  HorizontalAlignment="Left"
                  Background="#2764E7"
                  CornerRadius="22">
            <TextBlock Text="◉"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="35"
                       Foreground="White" />
          </Border>
          <TextBlock Margin="0,24,0,0"
                     Text="TaskLens"
                     FontSize="42"
                     FontWeight="Bold"
                     Foreground="#14213D" />
          <TextBlock x:Name="WelcomeTagline"
                     Margin="0,4,0,0"
                     FontSize="22"
                     Foreground="#2764E7" />
          <TextBlock x:Name="WelcomeBody"
                     MaxWidth="620"
                     Margin="0,22,0,0"
                     FontSize="16"
                     Foreground="#53627B" />
          <Border Margin="0,24"
                  Padding="16"
                  Background="#EDF6FF"
                  CornerRadius="13">
            <TextBlock x:Name="WelcomePrivacy" Foreground="#264B78" />
          </Border>
          <WrapPanel>
            <Button x:Name="WelcomeStart" FontSize="15" Click="WelcomeStart_Click" />
            <Button x:Name="WelcomeCheck" Style="{StaticResource QuietButton}" Click="WelcomeCheck_Click" />
            <Button x:Name="WelcomePrivacyButton" Style="{StaticResource QuietButton}" Click="WelcomePrivacy_Click" />
          </WrapPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
